### Pseudocódigo Kotlin para rolagem de dados

O roller do MVP deve ser simples, previsível e auditável. Nada de `eval`. O parser deve aceitar o básico primeiro: `NdM`, modificador fixo e depois, no release seguinte, referências a campos.

```kotlin
data class DiceExpression(
    val count: Int,
    val sides: Int,
    val modifier: Int = 0
)

data class DiceRollResult(
    val rolls: List<Int>,
    val modifier: Int,
    val total: Int,
    val expression: String
)

object DiceParser {
    // Aceita: 1d20, d20, 3d6+2, 2d10-1
    private val regex = Regex("""^\s*(\d*)d(\d+)\s*([+-]\s*\d+)?\s*$""")

    fun parse(input: String): DiceExpression {
        val match = regex.matchEntire(input)
            ?: error("Expressão de dado inválida: $input")

        val count = match.groupValues[1].ifBlank { "1" }.toInt()
        val sides = match.groupValues[2].toInt()
        val modifier = match.groupValues[3]
            .replace(" ", "")
            .ifBlank { "0" }
            .toInt()

        require(count in 1..100) { "Quantidade de dados fora do limite" }
        require(sides in 2..1000) { "Número de faces fora do limite" }

        return DiceExpression(count, sides, modifier)
    }
}

object DiceRoller {
    fun roll(expression: String, randomInt: (Int, Int) -> Int): DiceRollResult {
        val parsed = DiceParser.parse(expression)

        val rolls = buildList {
            repeat(parsed.count) {
                add(randomInt(1, parsed.sides))
            }
        }

        val total = rolls.sum() + parsed.modifier

        return DiceRollResult(
            rolls = rolls,
            modifier = parsed.modifier,
            total = total,
            expression = expression
        )
    }
}
```

Para aproximar a ergonomia do mRPG, a etapa seguinte é resolver referências de ficha antes do parse:

```kotlin
fun substituteSheetKeys(
    expression: String,
    values: Map<String, String>
): String {
    // Exemplo: "1d20 + str_mod + prof"
    var result = expression
    values.forEach { (key, value) ->
        result = result.replace("""\b$key\b""".toRegex(), value)
    }
    return result
}
```

### Pseudocódigo Kotlin para ficha customizada e campos calculados

A principal escolha de produto aqui é **limitar a linguagem de fórmula**. Para o MVP, basta resolver dependências simples e impedir ciclos.

```kotlin
class SheetEngine {

    fun evaluateComputedFields(
        template: SheetTemplate,
        rawValues: Map<String, String>
    ): Map<String, String> {
        val resolved = rawValues.toMutableMap()

        val computedFields = template.sections
            .flatMap { it.fields }
            .filter { it.type == FieldType.COMPUTED && !it.formula.isNullOrBlank() }

        repeat(computedFields.size) {
            var changed = false

            for (field in computedFields) {
                val substituted = substituteKeys(field.formula!!, resolved)
                val evaluated = safeArithmeticEval(substituted)

                if (resolved[field.key] != evaluated) {
                    resolved[field.key] = evaluated
                    changed = true
                }
            }

            if (!changed) return resolved
        }

        error("Ciclo detectado em campos computados")
    }

    private fun substituteKeys(
        formula: String,
        values: Map<String, String>
    ): String {
        var result = formula
        values.forEach { (key, value) ->
            result = result.replace("""\b$key\b""".toRegex(), value)
        }
        return result
    }

    private fun safeArithmeticEval(input: String): String {
        // Pseudocódigo: aceitar apenas números, + - * / () e espaços.
        require(input.matches(Regex("""^[\d+\-*/().\s]+$"""))) {
            "Fórmula contém tokens não permitidos"
        }
        return ArithmeticEvaluator.eval(input).toString()
    }
}
```

### Pseudocódigo Kotlin para salvamento local e sincronização

Aqui está a diferença entre um clone frágil e um sucessor realmente sólido: toda escrita vai para o banco local **antes** de falar com a rede.

```kotlin
class MessageRepository(
    private val messageDao: MessageDao,
    private val outboxDao: OutboxDao,
    private val clock: () -> Long,
    private val json: Json
) {

    suspend fun sendTextMessage(
        campaignId: String,
        senderUserId: String,
        senderCharacterId: String?,
        body: String
    ) {
        val now = clock()

        val message = ChatMessage(
            id = generateUuid(),
            campaignId = campaignId,
            senderUserId = senderUserId,
            senderCharacterId = senderCharacterId,
            kind = MessageKind.TEXT,
            body = body,
            imageUrl = null,
            rollResultJson = null,
            createdAt = now,
            syncStatus = EntitySyncStatus.LOCAL_ONLY
        )

        messageDao.insert(message)

        outboxDao.insert(
            OutboxEvent(
                id = generateUuid(),
                entityType = "message",
                entityId = message.id,
                operation = "CREATE",
                payloadJson = json.encodeToString(ChatMessage.serializer(), message),
                attempts = 0,
                nextRetryAt = now
            )
        )
    }
}
```

Worker de sincronização:

```kotlin
class SyncOutboxWorker(
    appContext: Context,
    params: WorkerParameters,
    private val api: SyncApi,
    private val outboxDao: OutboxDao,
    private val messageDao: MessageDao,
    private val json: Json
) : CoroutineWorker(appContext, params) {

    override suspend fun doWork(): Result {
        val pending = outboxDao.findReady(limit = 50)

        for (event in pending) {
            try {
                when (event.entityType) {
                    "message" -> syncMessageCreate(event)
                    else -> Unit
                }
                outboxDao.delete(event.id)
            } catch (ex: IOException) {
                outboxDao.reschedule(
                    id = event.id,
                    attempts = event.attempts + 1,
                    nextRetryAt = computeBackoff(event.attempts + 1)
                )
                return Result.retry()
            } catch (ex: HttpException) {
                if (ex.code() in 400..499) {
                    outboxDao.markDeadLetter(event.id, ex.code())
                } else {
                    outboxDao.reschedule(
                        id = event.id,
                        attempts = event.attempts + 1,
                        nextRetryAt = computeBackoff(event.attempts + 1)
                    )
                    return Result.retry()
                }
            }
        }

        return Result.success()
    }

    private suspend fun syncMessageCreate(event: OutboxEvent) {
        val message = json.decodeFromString(ChatMessage.serializer(), event.payloadJson)
        val serverCopy = api.createMessage(message)
        messageDao.markSynced(localId = message.id, serverTimestamp = serverCopy.createdAt)
    }

    private fun computeBackoff(attempts: Int): Long {
        val seconds = minOf(300, 2.0.pow(attempts.toDouble()).toLong())
        return System.currentTimeMillis() + seconds * 1000
    }
}
```

Agendamento do Worker:

```kotlin
fun enqueueSync(context: Context) {
    val request = OneTimeWorkRequestBuilder<SyncOutboxWorker>()
        .setConstraints(
            Constraints.Builder()
                .setRequiredNetworkType(NetworkType.CONNECTED)
                .build()
        )
        .build()

    WorkManager.getInstance(context).enqueueUniqueWork(
        "sync-outbox",
        ExistingWorkPolicy.KEEP,
        request
    )
}
```

Esse padrão permite três comportamentos que valem ouro para um sucessor espiritual do mRPG:

- jogar mesmo com rede instável;
- não perder mensagem digitada;
- recuperar o estado após crash, reboot ou retomada do app.

A lição mais forte que sai da pesquisa é simples: o mRPG era amado **não** porque fazia tudo, mas porque combinava, num fluxo leve de celular, **descoberta pública de campanhas**, **chat por persona** e **fichas realmente customizáveis**. O MVP certo é o que reconstrói esse trio com muito mais confiabilidade do que o original conseguiu sustentar nos seus últimos anos. citeturn42view0turn49view0turn12search1turn22view0turn38view0